<?xml version="1.0" encoding="utf-8"?>

<ContentView x:Class="DSoft.Maui.Controls.SegmentedControl"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:DSoft.Maui.Controls">
    <Border
        x:Name="OuterBorder"
        BackgroundColor="{Binding TrackColor, Source={RelativeSource AncestorType={x:Type local:SegmentedControl}}}"
        StrokeThickness="{Binding BorderThickness, Source={RelativeSource AncestorType={x:Type local:SegmentedControl}}}"
        Stroke="{Binding BorderColor, Source={RelativeSource AncestorType={x:Type local:SegmentedControl}}}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{Binding CornerRadius, Source={RelativeSource AncestorType={x:Type local:SegmentedControl}}}" />
        </Border.StrokeShape>
        <Grid x:Name="SegmentsGrid" ColumnSpacing="0" />
    </Border>
</ContentView>