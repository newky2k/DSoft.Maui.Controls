<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mauic="http://dsoft.maui/schemas/controls"             
             x:Class="MauiSampleApp.MainPage"
             Title="Demo">

    <ScrollView>
        <VerticalStackLayout>
            <Button Margin="30,5,30,5" Text="Charts" Clicked="OnChartsButtonClicked" />
            <Button Margin="30,5,30,5" Text="Controls" Clicked="OnControlsClicked" />
            <Button Margin="30,5,30,5" Text="PinchPan" Clicked="OnPanZoomClicked" />
            <Button Margin="30,5,30,5" Text="Color Picker" Clicked="OnColorPickerClicked" />
            <Button Margin="30,5,30,5" Text="Wizard Control" Clicked="OnWizardPageClicked" />
            <Button Margin="30,5,30,5" Text="Segmented Control" Clicked="OnSegmentedControlPageClicked" />
            <Button Margin="30,5,30,5" Text="Heatmap" Clicked="OnHeatmapPageClicked" />
            <Button Margin="30,5,30,5" Text="Signature Pad" Clicked="OnSignaturePadPageClicked" />
            <Button Margin="30,5,30,5" Text="Tab View" Clicked="OnTabViewPageClicked" />
            <Button Margin="30,5,30,5" Text="Data Grid" Clicked="OnDataGridPageClicked" />
            <Button Margin="30,5,30,5" Text="Spinner Picker" Clicked="OnSpinnerPickerPageClicked" />
            <Button Margin="30,5,30,5" Text="Date Picker" Clicked="OnDatePickerPageClicked" />
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
